          "schema": {
            "type": "string"
          },
          "name": "id",
          "in": "path",
          "required": true,
          "description": "The id of the lead you want to view or update."
        }
      ],
      "get": {
        "summary": "Get an Individual Staff",
        "tags": [],
        "responses": {
          "200": {
            "description": "OK",
