                    "schema": {
                        "type": "string"
                    },
                    "name": "version_number",
                    "in": "path",
                    "required": true,
                    "description": "The number of the specific version of this document to download."
                }
            ],
            "get": {
                "summary": "Download a Document Version",
                "tags": [],
                "responses": {
                    "302": {
                        "description": "Found",
                        "headers": {
                            "Location": {
                                "schema": {
                                    "type": "string"
                                },
                                "description": "Temporary URL to download document data (valid for 1 hour)"
                            }
                        }
                    }
                },
                "operationId": "get-v1-documents-id-versions-version_number-data",
                "description": "Download a specific document version."
            }
        },
        "/v1/documents/{id}/versions/{version_number}": {
            "parameters": [
                {
                    "schema": {
                        "type": "string"
                    },
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "The id of the document you want to view or update."
                },
                {
                    "schema": {
                        "type": "string"
                    },
                    "name": "version_number",
                    "in": "path",
                    "required": true,
                    "description": "The number of the specific version of this document."
                }
            ],
            "delete": {
                "summary": "Delete an Individual Document Version",
                "operationId": "delete-v1-documents-id-versions-version_number",
