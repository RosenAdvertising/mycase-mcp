            "get": {
                "summary": "Download a Document",
                "tags": [],
                "responses": {
                    "302": {
                        "description": "Found",
                        "headers": {
                            "Location": {
                                "schema": {
                                    "type": "string"
                                },
                                "description": "Temporary URL to download document data (valid for 1 minute)"
                            }
                        }
                    }
                },
                "operationId": "get-v1-documents-id-data",
                "description": "Download a specific document."
            }
