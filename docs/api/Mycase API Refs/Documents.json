        "/v1/documents/{id}/versions/{version_number}/data": {
            "parameters": [
                {
                    "schema": {
                        "type": "string"
                    },
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "The id of the document to download a version of."
