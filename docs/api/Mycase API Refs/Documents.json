                "summary": "Create a Firm Document",
                "operationId": "post-v1-documents",
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DocumentPostResponse"
                                }
                            }
                        }
                    }
                },
                "description": "Create an individual document not associated with a case.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/FirmDocumentRequest"
                            }
                        }
                    }
                }
            },
            "parameters": []
        },
