    "paths": {
        "/v1/documents": {
            "get": {
                "summary": "Get Documents",
                "tags": [],
                "responses": {
                    "200": {
                        "description": "OK",
                        "headers": {
                            "Link": {
                                "$ref": "#/components/headers/paginationLink"
                            },
                            "Item-Count": {
                                "$ref": "#/components/headers/paginationCount"
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DocumentResponse"
                                    }
                                }
                            }
                        }
                    }
                },
                "operationId": "get-v1-documents",
                "description": "Get all firm documents viewable by the authorized user.",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/PageSize"
                    },
                    {
                        "$ref": "#/components/parameters/FilterUpdatedAfter"
                    }
                ]
            },
