{
    "openapi": "3.1.0",
    "x-stoplight": {
        "id": "tj17y5rz7vsh0"
    },
    "info": {
        "title": "Tasks",
        "version": "1.0",
        "description": "Tasks API",
        "contact": {
            "name": "MyCase"
        }
    },
    "servers": [
        {
            "url": "https://external-integrations.mycase.com"
        }
    ],
    "paths": {
        "/v1/tasks": {
            "get": {
                "summary": "Get Tasks",
                "tags": [],
                "responses": {
                    "200": {
                        "description": "OK",
                        "headers": {
                            "Link": {
                                "$ref": "#/components/headers/Cases_PaginationLink"
                            },
                            "Item-Count": {
                                "$ref": "#/components/headers/Cases_PaginationCount"
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/TaskResponse"
                                    }
                                }
                            }
                        }
                    }
                },
                "operationId": "get-v1-tasks",
                "description": "Get all firm tasks viewable by the authorized user.",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/PageSize"
                    },
                    {
                        "$ref": "#/components/parameters/FilterUpdatedAfter"
                    }
                ]
            },
            "post": {
                "summary": "Create a Task",
                "operationId": "post-v1-tasks",
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TaskResponse"
                                }
                            }
                        }
                    }
                },
                "description": "Create an individual task.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/TaskRequest"
                            }
                        }
                    }
                }
            },
            "parameters": []
        },
        "/v1/tasks/{id}": {
            "put": {
                "summary": "Update an Individual Task",
                "operationId": "put-v1-tasks-id",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                },
                "description": "Allows you to edit a specfic task, based on the authorized user/firm priviledges.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/TaskRequest"
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete an Individual Task",
                "operationId": "delete-v1-tasks-id",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                },
                "description": "Allows you to delete a specfic task, based on the authorized user/firm priviledges."
            },
            "parameters": [
                {
                    "schema": {
                        "type": "string"
                    },
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "The id of the task you want to view or update."
                }
            ]
        },
        "/v1/tasks/{id}/relationships/staff": {
            "parameters": [
                {
                    "schema": {
                        "type": "string"
                    },
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "The id of the task you want to add staff to."
                }
            ],
            "post": {
                "summary": "Create a Staff Relationship for a Task",
                "operationId": "post-v1-tasks-id-relationships-staff",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                },
                "description": "Create a staff relationship for a specified task.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/TaskStaffRelationshipRequest"
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "parameters": {
            "FilterUpdatedAfter": {
                "title": "FilterUpdatedAfterParam",
                "name": "filter[updated_after]",
                "in": "query",
                "required": false,
                "description": "Filters the response to return only resources that are created or updated after a specified date/time. ISO 8610 date format. Results are inclusive of the date/time entered. Can include time but does not need to.",
                "schema": {
                    "type": "string",
                    "example": "?filter[updated_after]=2022-03-17T21:00:00Z"
                }
            },
            "PageSize": {
                "title": "PageSizeParam",
                "name": "page_size",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "number",
                    "default": "25",
                    "example": "?page_size=100",
                    "maximum": 1000,
                    "minimum": 1
                },
                "description": "The ability to specify the number of resources that are returned per response page."
            }
        },
        "schemas": {
            "TaskRequest": {
                "title": "TaskRequest",
                "x-stoplight": {
                    "id": "03h1v0ultbdm2"
                },
                "type": "object",
                "x-internal": false,
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of this task."
                    },
                    "description": {
                        "type": "string"
                    },
                    "priority": {
                        "type": "string",
                        "description": "The priority of this task. One of (Low | Medium | High)"
                    },
                    "due_date": {
                        "type": "string",
                        "description": "The due date of this task. Must be in ISO 8601 date format."
                    },
                    "completed": {
                        "type": "boolean",
                        "description": "Whether or not this task is completed."
                    },
                    "case": {
                        "type": "object",
                        "description": "The case associated with this task, if there is one.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "staff": {
                        "type": "array",
                        "description": "All staff associated with this task.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "integer"
                                }
                            }
                        }
                    }
                },
                "required": [
                    "name",
                    "priority",
                    "due_date",
                    "staff"
                ]
            },
            "TaskResponse": {
                "title": "EventResponse",
                "x-stoplight": {
                    "id": "2puc8lvh7n2kr"
                },
                "type": "object",
                "x-internal": false,
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string",
                        "description": "The name of this task."
                    },
                    "description": {
                        "type": "string"
                    },
                    "priority": {
                        "type": "string",
                        "description": "The priority of this task. One of (Low | Medium | High)"
                    },
                    "due_date": {
                        "type": "string",
                        "description": "The due date of this task in ISO 8601 date format."
                    },
                    "completed": {
                        "type": "boolean",
                        "description": "Whether or not this task is completed."
                    },
                    "case": {
                        "type": [
                            "object"
                        ],
                        "description": "The case associated with this task, if there is one.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "staff": {
                        "type": "array",
                        "description": "All staff associated with this task.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "integer"
                                }
                            }
                        }
                    },
                    "created_at": {
                        "type": "string"
                    },
                    "updated_at": {
                        "type": "string"
                    },
                    "completed_at": {
                        "type": "string",
                        "description": "Null if the task has not been completed."
                    }
                }
            },
            "TaskStaffRelationshipRequest": {
                "title": "EventStaffRelationshipRequest",
                "x-stoplight": {
                    "id": "phqta3apmukrl"
                },
                "type": "object",
                "x-internal": false,
                "properties": {
                    "staff": {
                        "type": "array",
                        "description": "A list of staff to add to the task.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "integer"
                                }
                            },
                            "required": [
                                "id"
                            ]
                        }
                    }
                }
            }
        },
        "headers": {
            "Cases_PaginationCount": {
                "description": "The total number of results.",
                "schema": {
                    "type": "number"
                }
            },
            "Cases_PaginationLink": {
                "description": "If there is another page of results, we provides you with the cursor to the next page using `page_token`. Please reference our pagination documentation for more info.",
                "schema": {
                    "type": "string"
                }
            }
        }
    }
}