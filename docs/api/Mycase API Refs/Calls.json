    "info": {
        "title": "Calls",
        "version": "1.0",
        "description": "Calls API"
    },
    "servers": [
        {
            "url": "https://external-integrations.mycase.com"
        }
    ],
    "paths": {
        "/v1/calls": {
            "get": {
                "summary": "Get Calls",
                "tags": [],
                "responses": {
                    "200": {
                        "description": "OK",
                        "headers": {
                            "Link": {
                                "$ref": "#/components/headers/Cases_PaginationLink"
                            },
                            "Item-Count": {
                                "$ref": "#/components/headers/Cases_PaginationCount"
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/CallResponse"
                                    }
                                }
                            }
                        }
                    }
                },
                "operationId": "get-v1-calls",
                "description": "Get all firm calls viewable by the authorized user.",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/PageSize"
                    },
                    {
                        "$ref": "#/components/parameters/FilterUpdatedAfter"
                    }
                ]
            },
            "post": {
                "summary": "Create a Call",
                "operationId": "post-v1-calls",
                "responses": {
                    "202": {
                        "description": "Accepted"
                    }
                },
                "description": "Create a call that will show up in the call log.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CallRequest"
                            }
                        }
                    }
                }
            }
        },
        "/v1/calls/{id}": {
            "put": {
                "summary": "Update an Individual Call",
                "operationId": "put-v1-calls-id",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                },
                "description": "Allows you to edit a specfic call, based on the authorized user/firm priviledges.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CallRequest"
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete an Individual Call",
                "operationId": "delete-v1-calls-id",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                },
                "description": "Allows you to delete a specfic call, based on the authorized user/firm priviledges."
            },
            "parameters": [
                {
                    "schema": {
                        "type": "string"
                    },
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "description": "The id of the call you want to view or update."
                }
            ]
        }
    },
    "components": {
        "schemas": {
            "CallRequest": {
                "title": "CallRequest",
                "x-stoplight": {
                    "id": "lxiy4j0k7lu2b"
                },
                "type": "object",
                "x-internal": false,
                "properties": {
                    "called_at": {
                        "description": "An ISO 8601 timestamp of when the call happened.",
                        "type": "string"
                    },
                    "caller_phone_number": {
                        "type": "string",
                        "description": "The caller's phone number."
                    },
                    "call_for": {
                        "type": "object",
                        "description": "The staff member that this call is associated with.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "message": {
                        "type": "string",
                        "description": "A description of the call."
                    },
                    "caller_name": {
                        "type": "string",
                        "description": "The caller's name. This field is mutually exclusive with fields `client` and `lead`. It is required to provide only one of the three."
                    },
                    "client": {
                        "type": "object",
                        "description": "The client that this call is associated with. This field is mutually exclusive with fields `caller_name` and `lead`. It is required to provide only one of the three.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "lead": {
                        "type": "object",
                        "description": "The lead that this call is associated with. This field is mutually exclusive with fields `client` and `caller_name`. It is required to provide only one of the three.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "call_type": {
                        "type": "string",
                        "description": "One of \"incoming\" or \"outgoing\". If no call type is added, we default to incoming."
                    },
                    "resolved": {
                        "type": "boolean",
                        "description": "Whether or not this call should show as resolved. Default is false."
                    }
                },
                "required": [
                    "called_at",
                    "caller_phone_number",
                    "call_for",
                    "message",
                    "caller_name",
                    "client",
                    "lead"
                ]
            },
            "CallResponse": {
                "title": "CallRequest",
                "x-stoplight": {
                    "id": "tgybk9jn65u3i"
                },
                "type": "object",
                "x-internal": false,
                "properties": {
                    "id": {
                        "type": "number",
                        "description": "A unique identifier for the call."
                    },
                    "called_at": {
                        "description": "An ISO 8601 timestamp of when the call happened.",
                        "type": "string"
                    },
                    "caller_phone_number": {
                        "type": "string",
                        "description": "The caller's phone number."
                    },
                    "call_for": {
                        "type": "object",
                        "description": "The staff member that this call is associated with.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "case": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "The case that this call is associated with.",
                        "x-stoplight": {
                            "id": "k213ub1bbp1nh"
                        },
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "lead": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "The lead that this call is associated with.",
                        "x-stoplight": {
                            "id": "k213ub1bbp1nh"
                        },
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "message": {
                        "type": "string",
                        "description": "A description of the call."
                    },
                    "caller_name": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "The caller's name. This field is mutually exclusive with the `client` field."
                    },
                    "client": {
                        "type": [
                            "object",
                            "null"
                        ],
                        "description": "The client that this call is associated with. This field is mutually exclusive with the `caller_name` field.",
                        "properties": {
                            "id": {
                                "type": "integer"
                            }
                        }
                    },
                    "call_type": {
                        "type": "string",
                        "description": "One of \"incoming\" or \"outgoing\"."
                    },
                    "resolved": {
                        "type": "boolean",
                        "description": "Whether or not this call is resolved."
                    },
                    "created_at": {
                        "type": "string",
                        "description": "The date the call was created in ISO 8601 date/time format."
                    },
                    "updated_at": {
                        "type": "string",
                        "description": "The date the call was last updated in ISO 8601 date/time format."
                    }
                }
            }
        },
        "parameters": {
            "FilterUpdatedAfter": {
                "title": "FilterUpdatedAfterParam",
                "name": "filter[updated_after]",
                "in": "query",
                "required": false,
                "description": "Filters the response to return only resources that are created or updated after a specified date/time. ISO 8610 date format. Results are inclusive of the date/time entered. Can include time but does not need to.",
                "schema": {
                    "type": "string",
                    "example": "?filter[updated_after]=2022-03-17T21:00:00Z"
                }
            },
            "PageSize": {
                "title": "PageSizeParam",
                "name": "page_size",
                "in": "query",
                "required": false,
                "schema": {
                    "type": "number",
                    "default": "25",
                    "example": "?page_size=100",
                    "maximum": 1000,
                    "minimum": 1
                },
                "description": "The ability to specify the number of resources that are returned per response page."
            }
        },
        "headers": {
            "Cases_PaginationCount": {
                "description": "The total number of results.",
                "schema": {
                    "type": "number"
                }
            },
            "Cases_PaginationLink": {
                "description": "If there is another page of results, we provides you with the cursor to the next page using `page_token`. Please reference our pagination documentation for more info.",
                "schema": {
                    "type": "string"
                }
            }
        }
    }
